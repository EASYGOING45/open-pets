{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenPets",
  "version": "0.1.0",
  "identifier": "run.crafter.openpets",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenPets",
        "width": 256,
        "height": 256,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.codex/pets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
