#!/usr/bin/env bash
# openpets-event — emit a pet state change to the OpenPets desktop app.
#
# Two modes:
#
#   openpets-event <state> [source]
#       Direct: write the given state to ~/.openpets/state.json.
#       Used for hooks where the right state is fixed (SessionStart→idle,
#       Stop→waving, etc).
#
#   openpets-event auto [source]
#       Smart: read Claude Code's hook JSON from stdin, infer the right
#       state from `hook_event_name` and `tool_response`. Used for
#       PostToolUse so a failed tool flips the pet to `failed`.
#
# Valid states: idle, running, running-right, running-left, waving,
#               jumping, failed, waiting, review
#
# `source` is just a tag for diagnostics. Defaults to "cli".
#
# Atomic write: temp file + mv. The watcher in the Tauri app subscribes to
# the directory (not the file), so an atomic rename is safe.

set -euo pipefail

dir="${HOME}/.openpets"
mkdir -p "$dir"

write_state() {
  local s="$1"
  local src="$2"
  local tmp
  tmp="${dir}/.state.tmp.$$"
  trap 'rm -f "$tmp"' RETURN
  printf '{"state":"%s","timestamp":%d,"source":"%s"}\n' \
    "$s" \
    "$(date +%s)" \
    "$src" \
    > "$tmp"
  mv -f "$tmp" "${dir}/state.json"
}

if [[ "${1:-}" == "auto" ]]; then
  source_label="${2:-claude-code}"

  # Inline Python: parse Claude Code's hook JSON, decide the state. Python 3
  # ships with macOS by default (and is on every dev machine that can run
  # Claude Code in the first place), so we don't need jq or a Rust helper.
  #
  # Note: we use `python3 -c "$(cat <<PY ... PY)"` rather than `python3 -`
  # because `python3 -` would attach the heredoc to python's stdin, leaving
  # nothing for `sys.stdin.read()` to consume. With -c, stdin stays as the
  # parent shell's stdin (the JSON pipe from the hook).
  #
  # WARNING — bash heredoc-in-$() trap: bash's parser scans `(` and `)` even
  # inside the heredoc body when it sits inside a $() substitution, so a
  # multi-line Python tuple like `x = (\n  "a",\n  "b",\n)` makes bash bail
  # with `unexpected EOF while looking for matching ')'` even though the
  # parens are perfectly balanced. Keep all `( … )` constructs in this
  # heredoc on a single line. Use `[ … ]` lists for multi-element collections.
  state=$(python3 -c "$(cat <<'PY'
import json, sys
try:
    data = json.load(sys.stdin)
except Exception:
    print("running"); sys.exit()

ev = data.get("hook_event_name", "") or ""
resp = data.get("tool_response")

def is_error(r):
    if r is None:
        return False
    if isinstance(r, dict):
        # Explicit is_error flag from the tool contract.
        if r.get("is_error") is True:
            return True
        # Non-empty error / stderr fields.
        for key in ("error", "stderr", "errorMessage", "error_message"):
            v = r.get(key)
            if isinstance(v, str) and v.strip():
                return True
        # Non-zero exit code in any casing convention.
        rc = r.get("returnCode") or r.get("returncode") or r.get("exit_code") or r.get("exitCode")
        if rc is not None:
            try:
                if int(rc) != 0:
                    return True
            except (ValueError, TypeError):
                pass
        # Nested content blob (some tools wrap output).
        content = r.get("content")
        if isinstance(content, list):
            for item in content:
                if isinstance(item, dict) and is_error(item):
                    return True
    elif isinstance(r, str):
        low = r.lower()
        if "error" in low and "no error" not in low and "not an error" not in low:
            return True
    return False

if ev == "PostToolUse" and is_error(resp):
    print("failed")
elif ev == "PostToolUse":
    print("running")
elif ev == "PreToolUse":
    print("running")
elif ev == "Notification":
    # Direct hooks with matchers handle permission_prompt→review and
    # idle_prompt→waiting. This fallback uses the notification_type
    # field (the canonical discriminator per Claude Code docs) instead
    # of guessing from message text.
    ntype = (data.get("notification_type") or "").lower()
    if ntype == "permission_prompt":
        print("review")
    elif ntype == "idle_prompt":
        print("waiting")
elif ev == "UserPromptSubmit":
    print("running")
elif ev == "Stop":
    print("waving")
elif ev == "SubagentStop":
    # Sub-agent finished, but the main Claude session continues working.
    print("running")
elif ev in ("SessionStart", "SessionEnd"):
    print("idle")
else:
    print("running")
PY
)" 2>/dev/null || echo running)
  # Empty output is intentional — the inline Python emits "" for events
  # that should not change the pet state (e.g. an idle Notification ping).
  # Don't write anything in that case; the existing state.json stands.
  if [[ -z "$state" ]]; then
    exit 0
  fi
  write_state "$state" "$source_label"
  exit 0
fi

state="${1:-}"
source_label="${2:-cli}"

if [[ -z "$state" ]]; then
  cat >&2 <<'EOF'
usage: openpets-event <state> [source]
       openpets-event auto [source]   (parses Claude Code hook JSON on stdin)

valid states:
  idle, running, running-right, running-left, waving,
  jumping, failed, waiting, review
EOF
  exit 1
fi

write_state "$state" "$source_label"
